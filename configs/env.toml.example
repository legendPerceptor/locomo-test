# 本地环境配置 — 复制为 env.toml 后填入你的信息
# cp env.toml.example env.toml
# 此文件在 .gitignore 中，不会进 git

[gateway]
# port: 查看 openclaw.json → gateway.port
# token: 查看 openclaw.json → auth.token
port = 19790
token = "your-gateway-token"
# state_dir: OpenClaw 状态目录，存放 agents/sessions 等（必填）
# 查看 openclaw.json → stateDir，或 Gateway 启动日志中的 state directory
state_dir = ""

[openviking]
# port: 查看 OV 配置文件 (ov.conf) 或启动命令中的 --port
port = 2936

[ogmem]
# api_url: oGMemory HTTP 服务地址
api_url = "http://127.0.0.1:8090"
# docker_container: 用于等待 ingest 提取完成的容器名
docker_container = "ogmem"
# wait_timeout: 每个 ingest session 等待 after_turn background extract done 的最长秒数
wait_timeout = 900
wait_interval = 2.0
log_tail = 500

[judge]
# api_key: 火山引擎 ARK 控制台获取，或其他 LLM 服务商 API key（必填）
api_key = ""
base_url = "https://ark.cn-beijing.volces.com/api/v3"
model = ""                   # 必填，如 "doubao-seed-2-0-pro-260215"
api_format = "openai"        # openai / anthropic
parallel = 5
